# Groq API key (https://console.groq.com/keys). Required for fast cloud transcription + refining.
# If empty, falls back to local whisper-cli + claude CLI.
GROQ_API_KEY=

# Refiner model on Groq. Alternatives: llama-3.3-70b-versatile, llama-3.1-8b-instant,
# meta-llama/llama-4-scout-17b-16e-instruct, moonshotai/kimi-k2-instruct, openai/gpt-oss-20b.
GROQ_REFINER_MODEL=llama-3.1-8b-instant

# Few-shot: number of past (transcript, refined) pairs injected as examples in each refine call.
HISTORY_FEWSHOT_N=5

# Consolidation: run the profile-updater after every N refine calls.
CONSOLIDATE_EVERY=20
